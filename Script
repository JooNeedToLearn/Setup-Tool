#!/system/bin/sh

BASE="https://raw.githubusercontent.com/JooNeedToLearn/Setup-Tool/main/apk"
DL="/sdcard/Download/KelNara-APK"
TMP="/data/local/tmp/kelnara-apk"

mkdir -p "$DL"

echo "[1] Cek root..."
if ! su -c "id" 2>/dev/null | grep -q "uid=0"; then
  echo "ROOT GAGAL / belum diizinkan"
  exit 1
fi
echo "ROOT OK"

echo "[2] Setup developer options..."
su -c "settings put global development_settings_enabled 1"
su -c "wm size 720x1280"
su -c "wm density 192"
su -c "settings put global force_msaa 1"
su -c "settings put global disable_hw_overlays 1"
su -c "settings put global force_resizable_activities 1"
su -c "settings put global enable_freeform_support 1"
su -c "settings put global force_allow_on_external 1"
su -c "settings put global window_animation_scale 0"
su -c "settings put global transition_animation_scale 0"
su -c "settings put global animator_duration_scale 0"
su -c "mkdir -p '$TMP' && chmod 777 '$TMP'"

install_apk() {
  NAME="$1"
  URL="$2"
  APK="$DL/$NAME"
  DST="$TMP/$NAME"

  echo ""
  echo "[DOWNLOAD] $NAME"
  wget --no-check-certificate -O "$APK" "$URL"

  SIZE=$(wc -c < "$APK" 2>/dev/null | tr -d ' ')
  if [ -z "$SIZE" ] || [ "$SIZE" -lt 100000 ]; then
    echo "GAGAL: file kecil / link salah / APK belum diupload"
    return
  fi

  echo "[INSTALL] $NAME"
  su -c "cp '$APK' '$DST' && chmod 644 '$DST'"
  su -c "pm install -r -d '$DST'"
}

install_apk "NovaLauncher_8.1.1.apk" "$BASE/NovaLauncher_8.1.1.apk"
install_apk "MT_Manager.apk" "$BASE/MT_Manager.apk"
install_apk "ControlScreenRotation.apk" "$BASE/ControlScreenRotation.apk"

echo ""
echo "SELESAI"
