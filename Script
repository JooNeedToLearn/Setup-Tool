#!/system/bin/sh

PREFIX="${PREFIX:-/data/data/com.termux/files/usr}"
TMP="/data/local/tmp/kelnara-apk"
DL="/sdcard/Download/KelNara-APK"
TOOL="/sdcard/Download/KelNara"
REPO="deb https://packages.termux.dev/apt/termux-main stable main"

clear 2>/dev/null
echo "======================================"
echo "        KelNara Auto Setup Tool"
echo "======================================"

echo "[1] Fix repo Termux..."
mkdir -p "$PREFIX/etc/apt/sources.list.d" 2>/dev/null
rm -f "$PREFIX/etc/apt/sources.list.d"/* 2>/dev/null
echo "$REPO" > "$PREFIX/etc/apt/sources.list"
rm -rf "$PREFIX/var/lib/apt/lists"/* 2>/dev/null
apt update -y || pkg update -y

echo "[2] Install kebutuhan..."
pkg install -y python wget ca-certificates openssl || exit 1

echo "[3] Setup storage..."
termux-setup-storage >/dev/null 2>&1
sleep 1
mkdir -p "$DL" 2>/dev/null

echo "[4] Cek root..."
if ! su -c "id" 2>/dev/null | grep -q "uid=0"; then
  echo "ROOT GAGAL / belum diizinkan"
  exit 1
fi
echo "ROOT OK"

echo "[5] Setup Developer Options..."
su -c "settings put global development_settings_enabled 1"
su -c "wm size 720x1280"
su -c "wm density 192"
su -c "settings put global force_msaa 1"
su -c "settings put global disable_hw_overlays 1"
su -c "settings put global force_resizable_activities 1"
su -c "settings put global enable_freeform_support 1"
su -c "settings put global force_allow_on_external 1"
su -c "settings put global window_animation_scale 0"
su -c "settings put global transition_animation_scale 0"
su -c "settings put global animator_duration_scale 0"
su -c "mkdir -p '$TMP' && chmod 777 '$TMP'"

echo "[6] Membuat tool KelNara..."
cat > "$TOOL" <<'PY'
import html
import os
import re
import subprocess
import time
import urllib.request

DL = "/sdcard/Download/KelNara-APK"
TMP = "/data/local/tmp/kelnara-apk"
UA = "Mozilla/5.0 (Linux; Android 10; Mobile) Chrome/120"

APPS = [
    ("Control_Screen_Orientation.apk", "https://www.mediafire.com/file/oqc8wc1wuuk8c2h/Control+Screen+Orientation.apk/file"),
    ("NovaLauncher.apk", "https://www.mediafire.com/file/it4bihksgknn24f/NovaLauncher.apk/file"),
    ("MT_Manager.apk", "https://www.mediafire.com/file/wly7xabz7j5ixbt/MT+Manager.apk/file"),
]

os.makedirs(DL, exist_ok=True)

def root(cmd):
    return subprocess.run(["su", "-c", cmd], text=True, capture_output=True)

def get_page(url):
    req = urllib.request.Request(url, headers={"User-Agent": UA})
    with urllib.request.urlopen(req, timeout=90) as r:
        return r.read().decode("utf-8", "ignore")

def get_direct_link(url):
    print("[RESOLVE]", url)
    page = get_page(url)

    m = re.search(r'id="downloadButton"[^>]+href="([^"]+)"', page)
    if not m:
        m = re.search(r'href="([^"]+)"[^>]+id="downloadButton"', page)
    if not m:
        m = re.search(r'https://download[^"]+', page)

    if not m:
        raise Exception("Direct link MediaFire tidak ditemukan")

    direct = m.group(1) if m.lastindex else m.group(0)
    direct = html.unescape(direct).replace("\\/", "/")
    print("[DIRECT]", direct)
    return direct

def download(name, url):
    direct = get_direct_link(url)
    path = os.path.join(DL, name)

    print("[DOWNLOAD]", name)
    req = urllib.request.Request(direct, headers={"User-Agent": UA, "Referer": url})

    with urllib.request.urlopen(req, timeout=240) as r, open(path, "wb") as f:
        while True:
            data = r.read(1024 * 256)
            if not data:
                break
            f.write(data)

    size = os.path.getsize(path)
    if size < 100000:
        raise Exception("File terlalu kecil / gagal download")

    with open(path, "rb") as f:
        if f.read(4) != b"PK\x03\x04":
            raise Exception("File bukan APK valid")

    print("[OK]", path)
    return path

def install(path):
    name = os.path.basename(path)
    dst = TMP + "/" + name

    print("[INSTALL]", name)
    root(f"mkdir -p '{TMP}' && chmod 777 '{TMP}'")
    root(f"cp '{path}' '{dst}' && chmod 644 '{dst}'")

    r = root(f"pm install -r -d '{dst}'")
    out = r.stdout + r.stderr
    print(out.strip())

    return "Success" in out

def main():
    print("=================================")
    print(" KelNara MediaFire APK Installer")
    print("=================================")

    ok = 0
    fail = 0

    for name, url in APPS:
        try:
            apk = download(name, url)
            if install(apk):
                ok += 1
            else:
                fail += 1
        except Exception as e:
            fail += 1
            print("[FAILED]", name, e)
        time.sleep(1)

    print("=================================")
    print("Installed:", ok)
    print("Failed   :", fail)
    print("Folder   :", DL)
    print("=================================")

main()
PY

chmod +x "$TOOL"

echo "[7] Jalankan KelNara..."
su -c "export PATH=\$PATH:/data/data/com.termux/files/usr/bin && python '$TOOL'"
