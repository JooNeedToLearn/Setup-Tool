#!/bin/bash
cd

echo "[+] Setup storage..."
rm -rf /data/data/com.termux/files/home/storage 2>/dev/null
termux-setup-storage
sleep 2

echo "[+] Install kebutuhan Termux..."
yes | pkg update
yes | pkg upgrade
yes | pkg install python
yes | pkg install python-pip
yes | pkg install wget
pip install requests

echo "[+] Buat folder..."
mkdir -p /sdcard/Download/KelNara-APK

echo "[+] Buat shouko.py..."
cat > /sdcard/Download/shouko.py <<'PY'
import os, re, subprocess, requests, urllib.parse

GOFILE_ID = "QeEs1Q"
DIR = "/sdcard/Download/KelNara-APK"
TMP = "/data/local/tmp/kelnara-apk"

os.makedirs(DIR, exist_ok=True)

def root(cmd):
    return subprocess.run(["su", "-c", cmd], text=True, capture_output=True)

def clean(name):
    return re.sub(r"[^A-Za-z0-9._-]", "_", name)

def check_root():
    out = root("id").stdout + root("id").stderr
    return "uid=0" in out

def get_token():
    r = requests.post("https://api.gofile.io/accounts", timeout=30)
    return r.json()["data"]["token"]

def get_contents(token):
    h = {"Authorization": f"Bearer {token}"}
    url = f"https://api.gofile.io/contents/{GOFILE_ID}?wt=4fd6sg89d7s6&cache=true"
    r = requests.get(url, headers=h, timeout=30)
    data = r.json()
    if data.get("status") != "ok":
        print(data)
        raise Exception("Gagal ambil folder Gofile")
    return data["data"]

def collect_files(node):
    files = []
    for _, item in node.get("children", {}).items():
        if item.get("type") == "file":
            files.append(item)
        elif item.get("type") == "folder":
            files += collect_files(item)
    return files

def download_file(token, item):
    name = clean(item["name"])
    file_id = item["id"]
    server = item.get("serverChoosen") or item.get("server")
    path = f"{DIR}/{name}"

    if not server:
        print(f"[SKIP] Server tidak ditemukan: {name}")
        return None

    url = f"https://{server}.gofile.io/download/web/{file_id}/{urllib.parse.quote(item['name'])}"
    headers = {
        "Cookie": f"accountToken={token}",
        "User-Agent": "Mozilla/5.0 Android"
    }

    print(f"[DOWNLOAD] {name}")

    with requests.get(url, headers=headers, stream=True, timeout=180) as r:
        if r.status_code != 200:
            print(f"[FAILED] HTTP {r.status_code}: {name}")
            return None

        with open(path, "wb") as f:
            for chunk in r.iter_content(1024 * 256):
                if chunk:
                    f.write(chunk)

    if os.path.getsize(path) < 100000:
        print(f"[FAILED] File terlalu kecil: {name}")
        return None

    print(f"[OK] Saved: {path}")
    return path

def install_apk(path):
    name = os.path.basename(path)
    tmp = f"{TMP}/{name}"

    print(f"[INSTALL] {name}")
    root(f"mkdir -p '{TMP}' && chmod 777 '{TMP}'")
    root(f"cp '{path}' '{tmp}' && chmod 644 '{tmp}'")

    out = root(f"pm install -r -d '{tmp}'")
    result = out.stdout + out.stderr
    print(result.strip())

    return "Success" in result

print("=================================")
print(" KelNara Auto Setup APK")
print("=================================")

print("[CHECK] Root...")
if not check_root():
    print("[X] Root belum aktif / belum diizinkan.")
    exit()

print("[OK] Root aktif")

token = get_token()
data = get_contents(token)
files = collect_files(data)

print(f"[INFO] Total file ditemukan: {len(files)}")

ok = 0
fail = 0

for item in files:
    name = item.get("name", "")

    if not name.lower().endswith(".apk"):
        print(f"[SKIP] Bukan APK: {name}")
        continue

    apk = download_file(token, item)

    if apk and install_apk(apk):
        ok += 1
    else:
        fail += 1

print("=================================")
print(f"Installed: {ok}")
print(f"Failed   : {fail}")
print(f"Folder   : {DIR}")
print("=================================")
PY

echo "[+] Cek root..."
if ! command -v su >/dev/null 2>&1 || ! su -c 'exit' >/dev/null 2>&1; then
    echo "[X] Root belum aktif / belum diizinkan."
    echo "[!] shouko.py tetap dibuat di /sdcard/Download/shouko.py"
    exit
fi

echo "[+] Setup Developer Options..."
su -c "settings put global development_settings_enabled 1"
su -c "wm size 1280x720"
su -c "wm density 192"
su -c "settings put global force_msaa 1"
su -c "settings put global disable_hw_overlays 1"
su -c "settings put global force_resizable_activities 1"
su -c "settings put global enable_freeform_support 1"
su -c "settings put global force_desktop_mode_on_external_displays 1"
su -c "settings put global force_allow_on_external 1"
su -c "settings put global window_animation_scale 0"
su -c "settings put global transition_animation_scale 0"
su -c "settings put global animator_duration_scale 0"

echo "[+] Setup Termux Boot..."
mkdir -p ~/.termux/boot
cat > ~/.termux/boot/abcd.sh <<'BOOT'
#!/data/data/com.termux/files/usr/bin/bash
su -c "cd /sdcard/Download && export PATH=\$PATH:/data/data/com.termux/files/usr/bin && export TERM=xterm-256color && python ./shouko.py"
BOOT
chmod +x ~/.termux/boot/abcd.sh

echo "[+] Jalankan installer..."
su -c "am kill-all"
su -c "cd /sdcard/Download && export PATH=\$PATH:/data/data/com.termux/files/usr/bin && export TERM=xterm-256color && python ./shouko.py"
