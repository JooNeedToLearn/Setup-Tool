#!/system/bin/sh

PREFIX="${PREFIX:-/data/data/com.termux/files/usr}"
TMP="/data/local/tmp/kelnara-apk"
DL="/sdcard/Download/KelNara-APK"
REPO="deb https://packages.termux.dev/apt/termux-main stable main"

URL_CONTROL="https://github.com/JooNeedToLearn/Setup-Tool/releases/download/v1.0/Control.Screen.Orientation.apk"
URL_NOVA="https://github.com/JooNeedToLearn/Setup-Tool/releases/download/v1.0/NovaLauncher.apk"
URL_MT="https://github.com/JooNeedToLearn/Setup-Tool/releases/download/v1.0/MT.Manager.apk"

clear 2>/dev/null
echo "======================================"
echo "        KelNara Auto Setup Tool"
echo "======================================"

echo "[1] Fix repo Termux..."
mkdir -p "$PREFIX/etc/apt/sources.list.d" 2>/dev/null
rm -f "$PREFIX/etc/apt/sources.list.d"/* 2>/dev/null
echo "$REPO" > "$PREFIX/etc/apt/sources.list"
rm -rf "$PREFIX/var/lib/apt/lists"/* 2>/dev/null
apt update -y || pkg update -y

echo "[2] Install kebutuhan..."
pkg install -y wget ca-certificates openssl || {
  echo "[X] Gagal install wget. Cek internet/repo Termux."
  exit 1
}

echo "[3] Setup folder..."
mkdir -p "$DL" 2>/dev/null
if [ ! -d "$DL" ] || [ ! -w "$DL" ]; then
  DL="$HOME/KelNara-APK"
  mkdir -p "$DL" 2>/dev/null
fi
su -c "mkdir -p '$TMP' && chmod 777 '$TMP'" 2>/dev/null

echo "Folder APK: $DL"

echo "[4] Cek root..."
if ! su -c "id" 2>/dev/null | grep -q "uid=0"; then
  echo "[X] ROOT GAGAL / belum diizinkan. Aktifkan Root Option lalu izinkan Termux."
  exit 1
fi
echo "[OK] Root aktif."

echo "[5] Setup Developer Options..."
su -c "settings put global development_settings_enabled 1" 2>/dev/null
su -c "wm size 720x1280" 2>/dev/null
su -c "wm density 192" 2>/dev/null
su -c "settings put global force_msaa 1" 2>/dev/null
su -c "settings put global disable_hw_overlays 1" 2>/dev/null
su -c "settings put global force_resizable_activities 1" 2>/dev/null
su -c "settings put global enable_freeform_support 1" 2>/dev/null
su -c "settings put global force_allow_on_external 1" 2>/dev/null
su -c "settings put global window_animation_scale 0" 2>/dev/null
su -c "settings put global transition_animation_scale 0" 2>/dev/null
su -c "settings put global animator_duration_scale 0" 2>/dev/null

check_apk() {
  FILE="$1"
  SIZE=$(wc -c < "$FILE" 2>/dev/null | tr -d ' ')
  if [ -z "$SIZE" ] || [ "$SIZE" -lt 100000 ]; then
    return 1
  fi
  SIG=$(dd if="$FILE" bs=4 count=1 2>/dev/null)
  [ "$SIG" = "PK" ]
}

download_apk() {
  NAME="$1"
  URL="$2"
  OUT="$DL/$NAME"

  echo ""
  echo "[DOWNLOAD] $NAME"
  rm -f "$OUT"
  wget --no-check-certificate --content-disposition -O "$OUT" "$URL"

  if ! check_apk "$OUT"; then
    echo "[X] Download gagal / file bukan APK valid: $NAME"
    return 1
  fi

  echo "[OK] Saved: $OUT"
  return 0
}

install_apk() {
  NAME="$1"
  SRC="$DL/$NAME"
  DST="$TMP/$NAME"

  echo "[INSTALL] $NAME"
  su -c "cp '$SRC' '$DST' && chmod 644 '$DST'"

  OUT=$(su -c "pm install -r -d '$DST'" 2>&1)
  echo "$OUT"

  echo "$OUT" | grep -q "Success" && return 0

  echo "[RETRY] Install tanpa -d..."
  OUT=$(su -c "pm install -r '$DST'" 2>&1)
  echo "$OUT"
  echo "$OUT" | grep -q "Success"
}

OK=0
FAIL=0

if download_apk "Control.Screen.Orientation.apk" "$URL_CONTROL" && install_apk "Control.Screen.Orientation.apk"; then OK=$((OK+1)); else FAIL=$((FAIL+1)); fi
if download_apk "NovaLauncher.apk" "$URL_NOVA" && install_apk "NovaLauncher.apk"; then OK=$((OK+1)); else FAIL=$((FAIL+1)); fi
if download_apk "MT.Manager.apk" "$URL_MT" && install_apk "MT.Manager.apk"; then OK=$((OK+1)); else FAIL=$((FAIL+1)); fi

echo ""
echo "======================================"
echo "Installed: $OK"
echo "Failed   : $FAIL"
echo "Folder   : $DL"
echo "======================================"
